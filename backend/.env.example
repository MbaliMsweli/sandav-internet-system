# Copy this file to .env and fill in your real values

# Your DigitalOcean Managed PostgreSQL connection string
DATABASE_URL=postgresql://doadmin:PASSWORD@your-db-host.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# Optional: path to CA certificate file (if not using DATABASE_CA_CERT env var)
# DATABASE_CA_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# Port the backend listens on
PORT=3001

# JWT secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# The domain of your frontend — only this origin is allowed to call the API
# In development: http://localhost:3000
# In production:  https://sandavdigitalisp.co.za
CORS_ORIGIN=https://sandavdigitalisp.co.za
